# Choose one provider key at minimum
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_BACKUP=
OPENROUTER_MODEL=deepseek/deepseek-r1:free
# Alternative free model:
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional for future Hugging Face integrations
HUGGINGFACE_API_KEY=
HUGGINGFACE_API_KEY_BACKUP=
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct
GITHUB_PAT=

# Tracker extension ingest security
TRACKER_EXTENSION_TOKEN=
TRACKER_INGEST_CORS_ORIGIN=*
TRACKER_INGEST_MIN_CONFIDENCE=0.7

# Tracker database path (set to persistent disk path on Render, e.g. /var/data/tracker.db)
TRACKER_DB_PATH=
